FROM node:lts

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm ci

# Copy source (mounted by compose in debug, but copying keeps container runnable standalone)
COPY . .

# Expose Vite default dev port
EXPOSE 5173

# Start Vite dev server accessible from host
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
